FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

COPY docker/requirements.streaming.txt /tmp/requirements.streaming.txt
RUN pip install --no-cache-dir -r /tmp/requirements.streaming.txt

COPY src /app/src
